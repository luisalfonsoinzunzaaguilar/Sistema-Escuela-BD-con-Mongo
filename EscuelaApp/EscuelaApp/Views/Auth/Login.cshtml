@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Login — EscuelaApp</title>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body class="auth-page">
<div class="auth-box">
    <h1>🎓 EscuelaApp</h1>
    <h2>Iniciar sesión</h2>

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="alert alert-error"></div>

        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" type="email" placeholder="demo@demo.com" />
            <span asp-validation-for="Email" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Contraseña</label>
            <input asp-for="Password" type="password" placeholder="••••••••" />
            <span asp-validation-for="Password" class="error"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-full">Entrar</button>
    </form>

    <p class="auth-link">¿No tienes cuenta? <a asp-action="Register">Regístrate</a></p>
    <p class="demo-hint">Demo: demo@demo.com / Demo1234</p>
</div>
</body>
</html>
