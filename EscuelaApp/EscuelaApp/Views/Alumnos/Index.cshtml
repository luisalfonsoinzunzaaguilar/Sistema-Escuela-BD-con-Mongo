@* Index.cshtml *@
@model List<Alumno>
@{
    ViewData["Title"] = "Alumnos";
}

<div class="page-header">
    <h2>Alumnos</h2>
    <a asp-action="Crear" class="btn btn-primary">+ Nuevo alumno</a>
</div>

@if (!Model.Any())
{
    <p class="empty-msg">No hay alumnos registrados aún.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Matrícula</th>
                <th>Carrera</th>
                <th>Email</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.Nombre</td>
                    <td>@a.Matricula</td>
                    <td>@a.Carrera</td>
                    <td>@a.Email</td>
                    <td class="actions">
                        <a asp-action="Detalle" asp-route-id="@a.Id" class="btn btn-sm btn-outline">Ver</a>
                        <a asp-action="Editar"  asp-route-id="@a.Id" class="btn btn-sm btn-secondary">Editar</a>
                        <a asp-action="Eliminar" asp-route-id="@a.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
